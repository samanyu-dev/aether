{
  "name": "aether-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix apps/web && pip3 install -r backend/requirements.txt",
    "dev:web": "npm run dev --prefix apps/web -- -p 3000",
    "dev:backend": "cd backend && python3 main.py",
    "demo:generate": "python3 packages/sdk-python/generate_recordings.py",
    "demo:run": "python3 packages/sdk-python/demo.py",
    "start": "npx concurrently \"npm run dev:web\" \"npm run dev:backend\"",
    "record:low": "node recordings/record_demo.js low",
    "record:medium": "node recordings/record_demo.js medium",
    "record:high": "node recordings/record_demo.js high",
    "deploy:hf": "node scripts/deploy_hf.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "playwright": "^1.40.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
